    "esbuild": "^0.28.0",
    "obsidian": "^1.5.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "preact": "^10.20.0",
    "@hello-pangea/dnd": "^16.6.0"
  }
}
